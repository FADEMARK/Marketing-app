<!DOCTYPE html>
<html lang="es">
<head>
  <title>Editor — <%= campaign.product_service %> — MarketingHub</title>
  <%- include('partials/head') %>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Anton&family=Bebas+Neue&family=Montserrat:wght@500;700;800&family=Poppins:wght@400;500;600;700&family=Oswald:wght@500;700&family=Playfair+Display:wght@700;900&family=Raleway:wght@400;700&family=Lato:wght@400;700&display=swap"
    rel="stylesheet"
  />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.0/fabric.min.js"></script>
</head>
<body>
  <%- include('partials/nav') %>

  <main class="page">
    <a href="/campaigns/<%= campaign.id %>" class="back-link">&larr; Volver a la campaña</a>

    <div class="page-header">
      <h1>Personaliza tu imagen</h1>
    </div>
    <% if (typeof initialCanvasState !== 'undefined' && initialCanvasState) { %>
      <p class="muted">
        Recuperamos tu edición anterior tal como la dejaste — sigue ajustándola libremente, no se
        gasta otra generación de IA por volver a entrar.
      </p>
    <% } else { %>
      <p class="muted">
        La IA ya generó el diseño completo (texto, logo e insignias incluidos). Revísalo con calma: si
        alguna palabra salió mal escrita o alguna letra se ve rara, usa "Parche de corrección" para
        taparla y escribe la palabra correcta encima — no hace falta generar de nuevo. También puedes
        agregar formas, íconos o texto extra si quieres.
      </p>
    <% } %>

    <div class="editor-layout">
      <aside class="editor-toolbar">
        <div class="tool-group" style="background: var(--bg); border: 1px solid var(--primary); border-radius: 8px; padding: 10px;">
          <h4 style="color: var(--primary);">Parche de corrección</h4>
          <button type="button" class="tool-btn" id="btn-color-patch">🩹 Corregir una palabra</button>
          <p class="muted small" style="margin-top:6px;">
            1) Clic aquí. 2) Clic sobre el diseño, cerca del error, para copiar ese color. 3) Mueve/ajusta
            el parche hasta tapar el texto malo. 4) Agrega arriba un texto nuevo con la palabra correcta.
          </p>
        </div>

        <div class="tool-group">
          <h4>Texto</h4>
          <button type="button" class="tool-btn" id="btn-add-text">+ Agregar texto</button>
          <button type="button" class="tool-btn" id="btn-add-post-texts">+ Agregar textos del post (título, mensaje, CTA, contacto)</button>
          <label class="muted small" style="display:block; margin-top:8px;">Tipo de letra</label>
          <select id="text-font">
            <option value="Montserrat, sans-serif">Montserrat</option>
            <option value="Poppins, sans-serif">Poppins</option>
            <option value="'Bebas Neue', sans-serif">Bebas Neue</option>
            <option value="Anton, sans-serif">Anton</option>
            <option value="Oswald, sans-serif">Oswald</option>
            <option value="'Playfair Display', serif">Playfair Display</option>
            <option value="Raleway, sans-serif">Raleway</option>
            <option value="Lato, sans-serif">Lato</option>
          </select>
          <label class="muted small" style="display:block; margin-top:8px;">Color de texto</label>
          <input type="color" id="text-color" value="#FFFFFF" />
          <label class="muted small" style="display:block; margin-top:8px;">Tamaño</label>
          <input type="range" id="text-size" min="14" max="120" value="36" style="width:100%;" />
        </div>

        <div class="tool-group">
          <h4>Autoformas</h4>
          <div class="shape-grid">
            <button type="button" class="tool-btn" data-shape="rect" title="Rectángulo">▭</button>
            <button type="button" class="tool-btn" data-shape="rrect" title="Rectángulo redondeado">▢</button>
            <button type="button" class="tool-btn" data-shape="circle" title="Círculo / óvalo">◯</button>
            <button type="button" class="tool-btn" data-shape="line" title="Línea">╱</button>
            <button type="button" class="tool-btn" data-shape="arrow" title="Flecha">➜</button>
            <button type="button" class="tool-btn" data-shape="star" title="Estrella / insignia">★</button>
          </div>
          <label class="muted small" style="display:block; margin-top:10px;">Color de forma</label>
          <input type="color" id="shape-color" value="<%= editorData.brandColorPrimary %>" />
        </div>

        <div class="tool-group">
          <h4>Íconos de contacto</h4>
          <div class="shape-grid">
            <button type="button" class="tool-btn icon-btn" data-icon="location" title="Ubicación / Dirección" style="color:#EA4335;">
              <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
            </button>
            <button type="button" class="tool-btn icon-btn" data-icon="phone" title="Teléfono" style="color:#1877F2;">
              <svg viewBox="0 0 24 24"><path fill="currentColor" d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
            </button>
            <button type="button" class="tool-btn icon-btn" data-icon="whatsapp" title="WhatsApp" style="color:#25D366;">
              <svg viewBox="0 0 24 24"><path fill="currentColor" d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 9h12v2H6V9zm8 5H6v-2h8v2zm4-6H6V6h12v2z"/></svg>
            </button>
            <button type="button" class="tool-btn icon-btn" data-icon="mail" title="Correo" style="color:#1877F2;">
              <svg viewBox="0 0 24 24"><path fill="currentColor" d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            </button>
          </div>
          <p class="muted small" style="margin-top:8px;">
            Se agregan con el color típico de cada uno — puedes recolorearlos abajo si prefieres que combinen con tu marca.
          </p>
        </div>

        <div class="tool-group">
          <h4>Íconos de marketing</h4>
          <div class="shape-grid">
            <button type="button" class="tool-btn icon-btn" data-icon="tag" title="Etiqueta de precio / oferta" style="color:#F59E0B;">
              <svg viewBox="0 0 24 24"><path fill="currentColor" d="M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.41l9 9c.36.36.86.59 1.41.59.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z"/></svg>
            </button>
            <button type="button" class="tool-btn icon-btn" data-icon="clock" title="Tiempo limitado" style="color:#111111;">
              <svg viewBox="0 0 24 24"><path fill="currentColor" d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
            </button>
            <button type="button" class="tool-btn icon-btn" data-icon="bolt" title="Oferta relámpago" style="color:#F59E0B;">
              <svg viewBox="0 0 24 24"><path fill="currentColor" d="M11 21h-1l1-7H7.5c-.58 0-.57-.32-.38-.66.19-.34.05-.08.07-.12C8.48 10.94 10.42 7.54 13 3h1l-1 7h3.5c.49 0 .56.33.47.51l-.07.15C12.96 17.55 11 21 11 21z"/></svg>
            </button>
            <button type="button" class="tool-btn icon-btn" data-icon="check" title="Garantía / beneficio" style="color:#22C55E;">
              <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            </button>
          </div>
        </div>

        <div class="tool-group">
          <h4>Redes sociales</h4>
          <div class="shape-grid">
            <button type="button" class="tool-btn icon-btn" data-social="facebook" title="Facebook">
              <span class="social-swatch" style="background:#1877F2; font-family:Georgia, serif; font-weight:700;">f</span>
            </button>
            <button type="button" class="tool-btn icon-btn" data-social="instagram" title="Instagram">
              <span class="social-swatch" style="background:linear-gradient(45deg,#FEDA75,#FA7E1E,#D62976,#962FBF); border-radius:6px;"></span>
            </button>
            <button type="button" class="tool-btn icon-btn" data-social="tiktok" title="TikTok">
              <span class="social-swatch" style="background:#010101; border-radius:6px;">♪</span>
            </button>
            <button type="button" class="tool-btn icon-btn" data-social="youtube" title="YouTube">
              <span class="social-swatch" style="background:#FF0000; border-radius:6px;">
                <span style="display:inline-block; width:0; height:0; border-top:5px solid transparent; border-bottom:5px solid transparent; border-left:8px solid #fff; margin-left:2px;"></span>
              </span>
            </button>
            <button type="button" class="tool-btn icon-btn" data-social="x" title="X (Twitter)">
              <span class="social-swatch" style="background:#000; border-radius:6px; font-weight:800;">X</span>
            </button>
            <button type="button" class="tool-btn icon-btn" data-social="linkedin" title="LinkedIn">
              <span class="social-swatch" style="background:#0A66C2; border-radius:6px; font-weight:800; font-size:10px;">in</span>
            </button>
          </div>
          <p class="muted small" style="margin-top:8px;">
            Insignias listas para poner junto a tu usuario/handle de cada red.
          </p>
        </div>

        <div class="tool-group">
          <h4>Logo</h4>
          <% if (editorData.logoDataUri) { %>
            <button type="button" class="tool-btn" id="btn-add-logo">+ Agregar logo</button>
          <% } else { %>
            <p class="muted small">No tienes un logo cargado. Súbelo desde "Mi negocio".</p>
          <% } %>
        </div>

        <div class="tool-group">
          <h4>Capas</h4>
          <button type="button" class="tool-btn" id="btn-front">Traer al frente</button>
          <button type="button" class="tool-btn" id="btn-back">Enviar atrás</button>
          <button type="button" class="tool-btn" id="btn-delete">Eliminar seleccionado</button>
        </div>
      </aside>

      <div>
        <div class="editor-canvas-wrap">
          <canvas id="editor-canvas" width="540" height="540"></canvas>
        </div>
        <div class="editor-actions">
          <button type="button" class="btn-secondary" id="btn-reset">Empezar de nuevo</button>
          <button type="button" class="btn-primary" id="btn-save">Guardar y continuar</button>
        </div>
        <p class="muted small" id="save-status" style="margin-top:8px;"></p>
      </div>
    </div>
  </main>

  <script>
    const backgroundImageData = <%- JSON.stringify(backgroundImageData) %>;
    const editorData = <%- JSON.stringify(editorData) %>;
    const initialCanvasState = <%- JSON.stringify(typeof initialCanvasState !== 'undefined' ? initialCanvasState : null) %>;
    const saveUrl = "/campaigns/<%= campaign.id %>/save-edited-image";

    const DISPLAY_SIZE = 540;
    const EXPORT_SIZE = 1080;

    const canvas = new fabric.Canvas("editor-canvas", {
      width: DISPLAY_SIZE,
      height: DISPLAY_SIZE,
      preserveObjectStacking: true,
    });

    // Tipografías de marketing (Google Fonts) que se pueden elegir para
    // cualquier texto. Las precargamos antes de dibujar nada en el lienzo
    // para que el primer render ya use la fuente correcta (si no, el canvas
    // a veces dibuja con la fuente de respaldo del sistema).
    const FONT_LOAD_SPECS = [
      "700 40px Montserrat",
      "600 40px Poppins",
      "400 40px 'Bebas Neue'",
      "400 40px Anton",
      "600 40px Oswald",
      "700 40px 'Playfair Display'",
      "700 40px Raleway",
      "700 40px Lato",
    ];

    function loadFonts() {
      if (!document.fonts || !document.fonts.load) return Promise.resolve();
      return Promise.all(
        FONT_LOAD_SPECS.map(function (spec) {
          return document.fonts.load(spec).catch(function () { return null; });
        })
      );
    }

    function loadBackground() {
      fabric.Image.fromURL(backgroundImageData, function (img) {
        img.scaleToWidth(DISPLAY_SIZE);
        img.scaleToHeight(DISPLAY_SIZE);
        canvas.setBackgroundImage(img, canvas.renderAll.bind(canvas), {
          originX: "left",
          originY: "top",
        });
      });
    }

    function addText(text, opts) {
      opts = opts || {};
      const defaultFont = document.getElementById("text-font")
        ? document.getElementById("text-font").value
        : "Montserrat, sans-serif";
      const t = new fabric.Textbox(text, Object.assign({
        left: 40,
        top: 40,
        width: DISPLAY_SIZE - 80,
        fontSize: 36,
        fill: "#FFFFFF",
        fontFamily: defaultFont,
        fontWeight: "600",
        textAlign: "center",
        shadow: "rgba(0,0,0,0.45) 0px 2px 6px",
      }, opts));
      canvas.add(t);
      canvas.setActiveObject(t);
      return t;
    }

    // La IA ya escribe el título/mensaje/CTA/contacto DENTRO del diseño, así
    // que ya NO los precargamos automáticamente (duplicaría el texto). Esta
    // función queda como una acción opcional ("+ Agregar textos del post")
    // por si el negocio quiere agregar alguno de estos como texto editable
    // extra — por ejemplo, para reforzar el CTA o agregarlo si la IA lo dejó
    // fuera. Usa una combinación de tipografías típica en diseño de
    // marketing: una fuente de impacto para el título, una legible para el
    // cuerpo, y algo con peso para el llamado a la acción.
    function addAllPostTexts() {
      let y = 36;
      if (editorData.headline) {
        addText(editorData.headline, {
          top: y,
          fontSize: 46,
          fontFamily: "Anton, sans-serif",
          fontWeight: "400",
        });
        y += 90;
      }
      if (editorData.keyMessage) {
        addText(editorData.keyMessage, {
          top: y,
          fontSize: 26,
          fontFamily: "Poppins, sans-serif",
          fontWeight: "500",
        });
        y += 70;
      }
      if (editorData.cta) {
        addText(editorData.cta, {
          top: DISPLAY_SIZE - 130,
          fontSize: 28,
          fontFamily: "Montserrat, sans-serif",
          fontWeight: "800",
          fill: "#FFFFFF",
        });
      }
      if (editorData.contactLine) {
        addText(editorData.contactLine, {
          top: DISPLAY_SIZE - 70,
          fontSize: 18,
          fontFamily: "Lato, sans-serif",
          fontWeight: "400",
        });
      }
      canvas.discardActiveObject();
      canvas.renderAll();
    }

    // Reconstruye exactamente lo que el negocio dejó guardado la última vez
    // (parches, textos, formas, íconos, logo) sobre el diseño — así puede
    // volver a editar sin tener que gastar otra generación de IA ni perder
    // su trabajo. Si nunca ha guardado nada, el lienzo arranca vacío sobre
    // el diseño tal como lo entregó la IA (ver comentario de addAllPostTexts).
    function restoreCanvasState(jsonStr) {
      let parsed;
      try {
        parsed = JSON.parse(jsonStr);
      } catch (err) {
        return;
      }
      const objects = (parsed && parsed.objects) || [];
      if (!objects.length) return;
      fabric.util.enlivenObjects(objects, function (enlivened) {
        enlivened.forEach(function (obj) { canvas.add(obj); });
        canvas.renderAll();
      });
    }

    function addLogo() {
      fabric.Image.fromURL(editorData.logoDataUri, function (img) {
        img.scaleToWidth(110);
        img.set({ left: DISPLAY_SIZE - 130, top: 20 });
        canvas.add(img);
        canvas.setActiveObject(img);
        canvas.renderAll();
      });
    }

    function addShape(type) {
      const color = document.getElementById("shape-color").value;
      let shape;
      switch (type) {
        case "rect":
          shape = new fabric.Rect({ left: 150, top: 150, width: 200, height: 120, fill: color });
          break;
        case "rrect":
          shape = new fabric.Rect({ left: 150, top: 150, width: 200, height: 120, rx: 24, ry: 24, fill: color });
          break;
        case "circle":
          shape = new fabric.Ellipse({ left: 150, top: 150, rx: 100, ry: 70, fill: color });
          break;
        case "line":
          shape = new fabric.Line([50, 50, 250, 50], { stroke: color, strokeWidth: 6 });
          break;
        case "arrow":
          shape = buildArrow(color);
          break;
        case "star":
          shape = buildStar(color);
          break;
        default:
          return;
      }
      canvas.add(shape);
      canvas.setActiveObject(shape);
      canvas.renderAll();
    }

    function buildArrow(color) {
      const points = [
        { x: 0, y: 20 }, { x: 120, y: 20 }, { x: 120, y: 0 }, { x: 170, y: 35 },
        { x: 120, y: 70 }, { x: 120, y: 50 }, { x: 0, y: 50 },
      ];
      return new fabric.Polygon(points, { left: 150, top: 200, fill: color });
    }

    function buildStar(color) {
      const spikes = 5;
      const outerRadius = 60;
      const innerRadius = 26;
      const points = [];
      for (let i = 0; i < spikes * 2; i++) {
        const radius = i % 2 === 0 ? outerRadius : innerRadius;
        const angle = (Math.PI / spikes) * i - Math.PI / 2;
        points.push({ x: outerRadius + radius * Math.cos(angle), y: outerRadius + radius * Math.sin(angle) });
      }
      return new fabric.Polygon(points, { left: 200, top: 200, fill: color });
    }

    // Íconos comunes en diseño de marketing (contacto y promociones), como
    // rutas vectoriales (Material Icons, licencia Apache 2.0 — libres de usar).
    // Se agregan con su color habitual, pero son formas normales: se pueden
    // recolorear, mover, redimensionar y borrar igual que cualquier otra.
    const ICONS = {
      location: {
        d: "M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z",
        color: "#EA4335",
      },
      phone: {
        d: "M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z",
        color: "#1877F2",
      },
      whatsapp: {
        d: "M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 9h12v2H6V9zm8 5H6v-2h8v2zm4-6H6V6h12v2z",
        color: "#25D366",
      },
      mail: {
        d: "M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z",
        color: "#1877F2",
      },
      tag: {
        d: "M21.41 11.58l-9-9C12.05 2.22 11.55 2 11 2H4c-1.1 0-2 .9-2 2v7c0 .55.22 1.05.59 1.41l9 9c.36.36.86.59 1.41.59.55 0 1.05-.22 1.41-.59l7-7c.37-.36.59-.86.59-1.41 0-.55-.23-1.06-.59-1.42zM5.5 7C4.67 7 4 6.33 4 5.5S4.67 4 5.5 4 7 4.67 7 5.5 6.33 7 5.5 7z",
        color: "#F59E0B",
      },
      clock: {
        d: "M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z",
        color: "#111111",
      },
      bolt: {
        d: "M11 21h-1l1-7H7.5c-.58 0-.57-.32-.38-.66.19-.34.05-.08.07-.12C8.48 10.94 10.42 7.54 13 3h1l-1 7h3.5c.49 0 .56.33.47.51l-.07.15C12.96 17.55 11 21 11 21z",
        color: "#F59E0B",
      },
      check: {
        d: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z",
        color: "#22C55E",
      },
    };

    function addIcon(key) {
      const icon = ICONS[key];
      if (!icon) return;
      const path = new fabric.Path(icon.d, {
        left: 180,
        top: 180,
        fill: icon.color,
        scaleX: 2.2,
        scaleY: 2.2,
        shadow: "rgba(0,0,0,0.35) 0px 1px 4px",
      });
      canvas.add(path);
      canvas.setActiveObject(path);
      canvas.renderAll();
    }

    // Insignias de redes sociales para que el negocio marque dónde seguirlo
    // (junto a su usuario/handle). Son formas simples armadas con
    // rectángulos/círculos + una letra o símbolo — no son el archivo oficial
    // de cada marca, pero se leen igual de claro y evitan depender de
    // recursos externos con licencias restringidas.
    const SOCIAL_BADGES = {
      facebook: function () {
        return new fabric.Group([
          new fabric.Circle({ left: 0, top: 0, radius: 40, fill: "#1877F2" }),
          new fabric.Text("f", {
            left: 30, top: 10, fontSize: 54, fontWeight: "700",
            fontFamily: "Georgia, 'Times New Roman', serif", fill: "#fff",
          }),
        ]);
      },
      instagram: function () {
        return new fabric.Group([
          new fabric.Rect({
            left: 0, top: 0, width: 80, height: 80, rx: 20, ry: 20,
            fill: new fabric.Gradient({
              type: "linear",
              coords: { x1: 0, y1: 80, x2: 80, y2: 0 },
              colorStops: [
                { offset: 0, color: "#FEDA75" },
                { offset: 0.3, color: "#FA7E1E" },
                { offset: 0.6, color: "#D62976" },
                { offset: 1, color: "#962FBF" },
              ],
            }),
          }),
          new fabric.Circle({ left: 22, top: 22, radius: 16, fill: "transparent", stroke: "#fff", strokeWidth: 6 }),
          new fabric.Circle({ left: 56, top: 12, radius: 4, fill: "#fff" }),
        ]);
      },
      tiktok: function () {
        return new fabric.Group([
          new fabric.Rect({ left: 0, top: 0, width: 80, height: 80, rx: 16, ry: 16, fill: "#010101" }),
          new fabric.Text("♪", { left: 20, top: 8, fontSize: 46, fill: "#25F4EE" }),
          new fabric.Text("♪", { left: 26, top: 14, fontSize: 46, fill: "#FE2C55" }),
          new fabric.Text("♪", { left: 23, top: 11, fontSize: 46, fill: "#fff" }),
        ]);
      },
      youtube: function () {
        return new fabric.Group([
          new fabric.Rect({ left: 0, top: 0, width: 80, height: 80, rx: 20, ry: 20, fill: "#FF0000" }),
          new fabric.Polygon([{ x: 30, y: 22 }, { x: 30, y: 58 }, { x: 58, y: 40 }], { fill: "#fff" }),
        ]);
      },
      x: function () {
        return new fabric.Group([
          new fabric.Rect({ left: 0, top: 0, width: 80, height: 80, rx: 16, ry: 16, fill: "#000000" }),
          new fabric.Text("X", {
            left: 21, top: 12, fontSize: 50, fontWeight: "800",
            fontFamily: "Helvetica, Arial, sans-serif", fill: "#fff",
          }),
        ]);
      },
      linkedin: function () {
        return new fabric.Group([
          new fabric.Rect({ left: 0, top: 0, width: 80, height: 80, rx: 16, ry: 16, fill: "#0A66C2" }),
          new fabric.Text("in", {
            left: 12, top: 22, fontSize: 34, fontWeight: "800",
            fontFamily: "Arial, sans-serif", fill: "#fff",
          }),
        ]);
      },
    };

    function addSocialBadge(key) {
      const factory = SOCIAL_BADGES[key];
      if (!factory) return;
      const badge = factory();
      badge.set({ left: 160, top: 160 });
      canvas.add(badge);
      canvas.setActiveObject(badge);
      canvas.renderAll();
    }

    document.getElementById("btn-add-text").addEventListener("click", function () {
      const color = document.getElementById("text-color").value;
      const size = parseInt(document.getElementById("text-size").value, 10);
      addText("Escribe aquí", { fill: color, fontSize: size, top: 200 });
    });

    document.getElementById("btn-add-post-texts").addEventListener("click", function () {
      addAllPostTexts();
    });

    // Herramienta de corrección: arma el flujo completo "clic para tomar el
    // color de fondo → aparece un rectángulo de ese color listo para mover y
    // agrandar" — así el negocio puede tapar una palabra mal escrita sin
    // tener que adivinar qué color de fondo usar.
    let colorPatchMode = false;
    const statusEl = document.getElementById("save-status");

    document.getElementById("btn-color-patch").addEventListener("click", function () {
      colorPatchMode = true;
      canvas.discardActiveObject();
      canvas.renderAll();
      canvas.defaultCursor = "crosshair";
      canvas.hoverCursor = "crosshair";
      if (statusEl) statusEl.textContent = "Haz clic sobre el diseño, junto al error, para tomar ese color…";
    });

    canvas.on("mouse:down", function (opt) {
      if (!colorPatchMode) return;
      const pointer = canvas.getPointer(opt.e);
      let hex = "#FFFFFF";
      try {
        const ctx = canvas.lowerCanvasEl.getContext("2d");
        const scaleX = canvas.lowerCanvasEl.width / canvas.getWidth();
        const scaleY = canvas.lowerCanvasEl.height / canvas.getHeight();
        const px = Math.max(0, Math.round(pointer.x * scaleX));
        const py = Math.max(0, Math.round(pointer.y * scaleY));
        const pixel = ctx.getImageData(px, py, 1, 1).data;
        hex = "#" + [pixel[0], pixel[1], pixel[2]].map(function (v) {
          return v.toString(16).padStart(2, "0");
        }).join("");
      } catch (err) {
        // si por lo que sea no se puede leer el pixel, seguimos con blanco
      }

      const patch = new fabric.Rect({
        left: pointer.x - 60,
        top: pointer.y - 18,
        width: 120,
        height: 36,
        fill: hex,
      });
      canvas.add(patch);
      canvas.setActiveObject(patch);
      canvas.renderAll();

      colorPatchMode = false;
      canvas.defaultCursor = "default";
      canvas.hoverCursor = "move";
      if (statusEl) {
        statusEl.textContent = "Listo — ajusta el tamaño/posición del parche y agrega el texto correcto encima.";
      }
    });

    document.querySelectorAll("[data-shape]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        addShape(btn.getAttribute("data-shape"));
      });
    });

    document.querySelectorAll("[data-icon]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        addIcon(btn.getAttribute("data-icon"));
      });
    });

    document.querySelectorAll("[data-social]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        addSocialBadge(btn.getAttribute("data-social"));
      });
    });

    document.getElementById("text-color").addEventListener("input", function (e) {
      const obj = canvas.getActiveObject();
      if (obj && obj.type === "textbox") {
        obj.set("fill", e.target.value);
        canvas.renderAll();
      }
    });

    document.getElementById("text-size").addEventListener("input", function (e) {
      const obj = canvas.getActiveObject();
      if (obj && obj.type === "textbox") {
        obj.set("fontSize", parseInt(e.target.value, 10));
        canvas.renderAll();
      }
    });

    document.getElementById("text-font").addEventListener("change", function (e) {
      const obj = canvas.getActiveObject();
      if (obj && obj.type === "textbox") {
        obj.set("fontFamily", e.target.value);
        canvas.renderAll();
      }
    });

    document.getElementById("shape-color").addEventListener("input", function (e) {
      const obj = canvas.getActiveObject();
      if (obj && obj.type !== "textbox" && obj.type !== "image" && obj.type !== "group") {
        obj.set("fill", e.target.value);
        canvas.renderAll();
      }
    });

    // Al seleccionar un objeto existente, refleja sus valores reales en los
    // controles (color, tamaño, fuente) — así no parece que el control "no
    // hace nada" cuando en realidad estaba desincronizado con la selección.
    function syncControlsToSelection() {
      const obj = canvas.getActiveObject();
      if (!obj) return;
      if (obj.type === "textbox") {
        if (typeof obj.fill === "string" && obj.fill.startsWith("#")) {
          document.getElementById("text-color").value = obj.fill;
        }
        document.getElementById("text-size").value = Math.round(obj.fontSize || 36);
        const fontSelect = document.getElementById("text-font");
        if (obj.fontFamily && Array.from(fontSelect.options).some((o) => o.value === obj.fontFamily)) {
          fontSelect.value = obj.fontFamily;
        }
      } else if (obj.type !== "image" && obj.type !== "group") {
        if (typeof obj.fill === "string" && obj.fill.startsWith("#")) {
          document.getElementById("shape-color").value = obj.fill;
        }
      }
    }
    canvas.on("selection:created", syncControlsToSelection);
    canvas.on("selection:updated", syncControlsToSelection);

    document.getElementById("btn-add-logo").addEventListener("click", addLogo);

    document.getElementById("btn-front").addEventListener("click", function () {
      const obj = canvas.getActiveObject();
      if (obj) canvas.bringToFront(obj);
    });
    document.getElementById("btn-back").addEventListener("click", function () {
      const obj = canvas.getActiveObject();
      if (obj) canvas.sendToBack(obj);
    });
    document.getElementById("btn-delete").addEventListener("click", function () {
      const obj = canvas.getActiveObject();
      if (obj) canvas.remove(obj);
    });

    document.getElementById("btn-reset").addEventListener("click", function () {
      if (!confirm("¿Borrar todos tus parches/textos/formas agregados y volver al diseño tal como lo entregó la IA?")) return;
      canvas.getObjects().slice().forEach(function (o) { canvas.remove(o); });
      canvas.discardActiveObject();
      canvas.renderAll();
    });

    document.getElementById("btn-save").addEventListener("click", function () {
      canvas.discardActiveObject();
      canvas.renderAll();
      const dataUrl = canvas.toDataURL({
        format: "png",
        multiplier: EXPORT_SIZE / DISPLAY_SIZE,
      });

      // Guardamos también el estado editable (textos/formas/íconos/logo) sin
      // el fondo — así, si el negocio vuelve a entrar al editor, se le
      // devuelve exactamente lo que dejó, sin gastar otra generación de IA.
      const stateJson = canvas.toJSON();
      delete stateJson.backgroundImage;
      const canvasStateStr = JSON.stringify(stateJson);

      const statusEl = document.getElementById("save-status");
      statusEl.textContent = "Guardando...";

      fetch(saveUrl, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ image: dataUrl, canvasState: canvasStateStr }),
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.ok) {
            statusEl.textContent = "¡Guardado!";
            window.location.href = data.redirect;
          } else {
            statusEl.textContent = data.error || "Ocurrió un error al guardar.";
          }
        })
        .catch(function () {
          statusEl.textContent = "Ocurrió un error al guardar. Intenta de nuevo.";
        });
    });

    loadFonts().then(function () {
      loadBackground();
      if (initialCanvasState) {
        restoreCanvasState(initialCanvasState);
      }
      // Si no hay estado guardado, el lienzo arranca vacío sobre el diseño
      // que entregó la IA — ya trae su propio texto/logo/insignias. El
      // negocio solo agrega algo encima si necesita corregir o reforzar.
    });
  </script>
</body>
</html>
