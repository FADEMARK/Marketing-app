<!DOCTYPE html>
<html lang="es">
<head>
  <title>Mi panel — MarketingHub</title>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/nav') %>

  <main class="page">
    <div class="page-header">
      <div>
        <h1><%= business.name %></h1>
        <p class="subtitle"><a href="<%= business.fb_page_link %>" target="_blank" rel="noopener">📘 <%= business.fb_page_link %></a></p>
      </div>
      <a href="/campaigns/new" class="btn-primary">+ Nueva publicación</a>
    </div>

    <% if (business.plan === 'fademarksuite') { %>
      <% var weekBatches = {}; %>
      <% campaigns.forEach(function(c) {
           if (c.week_batch_id) {
             weekBatches[c.week_batch_id] = weekBatches[c.week_batch_id] || { topic: c.week_topic, count: 0, created_at: c.created_at };
             weekBatches[c.week_batch_id].count++;
           }
         }); %>
      <div class="card-form" style="margin: 20px 0;">
        <div class="page-header" style="margin: 0;">
          <h3 style="margin: 0;">FadeMarkSuite — Semanas de contenido</h3>
          <a href="/week/new" class="btn-secondary">+ Nueva semana</a>
        </div>
        <% var batchIds = Object.keys(weekBatches); %>
        <% if (batchIds.length === 0) { %>
          <p class="muted small">Todavía no has generado ninguna semana de contenido.</p>
        <% } else { %>
          <div class="campaign-grid" style="margin-top: 14px;">
            <% batchIds.forEach(function(id) { %>
              <a href="/week/<%= id %>" class="campaign-card">
                <h3><%= weekBatches[id].topic || 'Varios temas' %></h3>
                <p class="muted small"><%= weekBatches[id].count %> publicaciones</p>
              </a>
            <% }); %>
          </div>
        <% } %>
      </div>
    <% } %>

    <% if (campaigns.length === 0) { %>
      <div class="empty-state">
        <p>Todavía no has creado ninguna publicación.</p>
        <a href="/campaigns/new" class="btn-primary">Crear mi primera publicación</a>
      </div>
    <% } else { %>
      <div class="campaign-grid">
        <% campaigns.filter(function(c) { return !c.week_batch_id; }).forEach(function(c) { %>
          <a href="/campaigns/<%= c.id %>" class="campaign-card">
            <span class="status-badge status-<%= c.status %>"><%= STATUS_LABELS[c.status] %></span>
            <h3><%= c.product_service %></h3>
            <p class="muted"><%= c.objective %></p>
            <p class="muted small">Creada el <%= c.created_at %></p>
          </a>
        <% }); %>
      </div>
    <% } %>
  </main>
</body>
</html>
