<!DOCTYPE html>
<html lang="es">
<head>
  <title>Mi negocio — MarketingHub</title>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/nav') %>

  <main class="form-page">
    <a href="/dashboard" class="back-link">&larr; Volver a mi panel</a>
    <h1>Editar mi negocio</h1>
    <p class="subtitle">Actualiza tus datos, colores de marca, logo o contraseña.</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-warning"><%= success %></div>
    <% } %>
    <% if (typeof fb_error !== 'undefined' && fb_error) { %>
      <div class="alert alert-error">Facebook: <%= fb_error %></div>
    <% } %>
    <% if (typeof fb_connected !== 'undefined' && fb_connected) { %>
      <div class="alert alert-warning">Página de Facebook conectada correctamente.</div>
    <% } %>

    <div class="card-form" style="margin-bottom: 24px;">
      <h3 style="margin: 0;">Publicación en Facebook</h3>
      <% if (business.fb_page_id) { %>
        <p>Conectado a: <strong><%= business.fb_page_name %></strong></p>
        <form method="POST" action="/facebook/disconnect">
          <button type="submit" class="link-button" style="color:#B3261E;">Desconectar página</button>
        </form>
      <% } else { %>
        <p class="muted">Conecta tu página para poder publicar directo desde el panel admin, sin subirla a mano.</p>
        <a href="/facebook/connect" class="btn-primary">Conectar con Facebook</a>
      <% } %>
    </div>

    <form method="POST" action="/profile" enctype="multipart/form-data" class="card-form">
      <label>Nombre del negocio *
        <input type="text" name="name" required value="<%= business.name || '' %>" />
      </label>

      <label>Link de tu página de Facebook *
        <input type="url" name="fb_page_link" required value="<%= business.fb_page_link || '' %>" />
      </label>

      <label>Giro del negocio *
        <input list="industries" type="text" name="industry" required value="<%= business.industry || '' %>" placeholder="Ej. Clínica dental, Restaurante, Gimnasio..." />
        <datalist id="industries">
          <option value="Clínica dental">
          <option value="Restaurante / Cafetería">
          <option value="Salón de belleza / Spa">
          <option value="Gimnasio / Fitness">
          <option value="Tienda de ropa / Boutique">
          <option value="Bienes raíces">
          <option value="Veterinaria">
          <option value="Consultorio médico">
          <option value="Ferretería">
          <option value="Escuela / Academia">
          <option value="Servicios profesionales (legal, contable, etc.)">
        </datalist>
      </label>

      <label>Teléfono / WhatsApp (se muestra en tus publicaciones)
        <input type="tel" name="phone" value="<%= business.phone || '' %>" placeholder="442 431 0914" />
      </label>

      <label>Dirección (se muestra en tus publicaciones)
        <input type="text" name="address" value="<%= business.address || '' %>" placeholder="Ej. Torre 1, piso 5, Centro Sur" />
      </label>

      <label>Nombre del doctor(a) o responsable (opcional — para consultorios médicos/dentales)
        <input type="text" name="doctor_name" value="<%= business.doctor_name || '' %>" placeholder="Ej. Dra. Ana López" />
      </label>

      <div class="two-col">
        <label>Color primario de marca
          <input type="color" name="brand_color_primary" value="<%= business.brand_color_primary || '#1877F2' %>" />
        </label>
        <label>Color secundario de marca
          <input type="color" name="brand_color_secondary" value="<%= business.brand_color_secondary || '#0B0B0B' %>" />
        </label>
      </div>

      <% if (business.logo_data) { %>
        <label>Logo actual
          <img class="logo-preview" src="<%= business.logo_data %>" alt="Logo actual" />
        </label>
      <% } %>
      <label>Reemplazar logo (opcional)
        <input type="file" name="logo" accept="image/*" />
      </label>

      <label>Nueva contraseña (opcional, déjalo vacío para no cambiarla)
        <input type="password" name="new_password" minlength="6" />
      </label>

      <button type="submit" class="btn-primary full-width">Guardar cambios</button>
    </form>
  </main>
</body>
</html>
