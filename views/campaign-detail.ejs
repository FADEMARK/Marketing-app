<!DOCTYPE html>
<html lang="es">
<head>
  <title><%= campaign.product_service %> — MarketingHub</title>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/nav') %>

  <main class="page narrow">
    <a href="/dashboard" class="back-link">&larr; Volver a mi panel</a>

    <div class="page-header">
      <h1><%= campaign.product_service %></h1>
      <span class="status-badge status-<%= campaign.status %>"><%= STATUS_LABELS[campaign.status] %></span>
    </div>

    <div class="detail-grid">
      <div class="detail-box">
        <h3>Tu brief</h3>
        <p><strong>Objetivo:</strong> <%= campaign.objective %></p>
        <p><strong>Mensaje clave:</strong> <%= campaign.key_message %></p>
        <p><strong>Público objetivo:</strong> <%= campaign.target_audience %></p>
        <p><strong>Tono:</strong> <%= campaign.tone %></p>
        <p><strong>Llamado a la acción:</strong> <%= campaign.cta %></p>
        <% if (campaign.desired_date) { %><p><strong>Fecha deseada:</strong> <%= campaign.desired_date %></p><% } %>
      </div>

      <% var isApproved = campaign.status === 'aprobado' || campaign.status === 'publicado'; %>
      <div class="detail-box">
        <h3>Propuesta de nuestro equipo</h3>
        <% if (campaign.final_image_data) { %>
          <img class="preview-image" src="<%= campaign.final_image_data %>" alt="Diseño final" />
          <% if (!isApproved) { %>
            <p class="muted small">
              Vista previa generada automáticamente — nuestro equipo todavía la está revisando antes
              de aprobarla/publicarla. Puede cambiar un poco antes de la versión final.
            </p>
          <% } %>
        <% } else if (campaign.canva_design_url) { %>
          <p><a href="<%= campaign.canva_design_url %>" target="_blank" rel="noopener">Ver borrador en Canva →</a></p>
        <% } else if (campaign.background_image_data) { %>
          <div style="background: var(--bg); border: 1px dashed var(--border); border-radius: 8px; padding: 16px;">
            <h4 style="margin-top:0;">Fondo generado por IA</h4>
            <p class="muted small">
              Este es solo el fondo — todavía falta agregarle tu texto, logo y formas. Usa el editor
              para terminarlo.
            </p>
            <img class="preview-image" src="<%= campaign.background_image_data %>" alt="Fondo generado" />

            <% if (typeof imageCandidates !== 'undefined' && imageCandidates && imageCandidates.length > 1) { %>
              <p class="muted small" style="margin-top:12px;"><strong>Otras versiones generadas:</strong></p>
              <div style="display:flex; gap:12px; flex-wrap:wrap;">
                <% imageCandidates.forEach(function(c) { %>
                  <div style="text-align:center;">
                    <img src="<%= c.dataUri %>" alt="<%= c.label %>" style="width:120px; height:120px; object-fit:cover; border-radius:6px; border:1px solid var(--border);" />
                    <p class="muted small" style="margin:4px 0;"><%= c.label %></p>
                    <form method="POST" action="/campaigns/<%= campaign.id %>/choose-background">
                      <input type="hidden" name="engine" value="<%= c.engine %>" />
                      <button type="submit" class="btn-secondary">Usar este fondo</button>
                    </form>
                  </div>
                <% }); %>
              </div>
            <% } %>

            <a href="/campaigns/<%= campaign.id %>/editor" class="btn-primary full-width" style="display:block; text-align:center; margin-top:16px;">
              Continuar en el editor →
            </a>
          </div>
        <% } else if (typeof imagePreview !== 'undefined' && imagePreview) { %>
          <div style="background: var(--bg); border: 1px dashed var(--border); border-radius: 8px; padding: 16px;">
            <h4 style="margin-top:0;">Esto es lo que se va a mandar para crear tu imagen</h4>
            <p class="muted small">
              Revisa que todo esté correcto antes de generar — la generación tiene un costo, así que
              mejor confirmar antes que repetirla.
            </p>

            <% if (imagePreview.logoDataUri) { %>
              <p class="muted small" style="margin-bottom:4px;"><strong>Logo:</strong></p>
              <img class="logo-preview" src="<%= imagePreview.logoDataUri %>" alt="Logo" />
            <% } else { %>
              <p class="muted small">
                <strong>Logo:</strong> no tienes uno cargado — súbelo desde "Mi negocio" si quieres
                que la IA lo tome en cuenta.
              </p>
            <% } %>
            <p class="muted small"><strong>Giro del negocio:</strong> <%= imagePreview.businessIndustry || '—' %></p>
            <p class="muted small"><strong>Contacto (dirección/teléfono):</strong> <%= imagePreview.contactLine || '—' %></p>
            <p class="muted small"><strong>Título (generado por IA):</strong> <%= imagePreview.headline %></p>
            <p class="muted small"><strong>Post generado:</strong> <%= imagePreview.postCaption %></p>
            <p class="muted small"><strong>Llamado a la acción:</strong> <%= imagePreview.cta %></p>
            <% if (imagePreview.hashtags) { %>
              <p class="muted small"><strong>Hashtags:</strong> <%= imagePreview.hashtags %></p>
            <% } %>
            <p class="muted small">
              Motor(es) de IA: Google Gemini<%= imagePreview.allowOpenAI ? ' + OpenAI (gpt-image-1) — plan Plus' : ' — plan Estándar' %>.
            </p>

            <details style="margin: 12px 0;">
              <summary class="link-strong" style="cursor:pointer;">Ver el prompt completo que se le mandará a la IA</summary>
              <pre style="white-space: pre-wrap; font-family: monospace; font-size: 0.78rem; background: var(--card-bg); padding: 12px; border-radius: 8px; max-height: 400px; overflow-y: auto; margin-top: 8px;"><%= imagePreview.promptPreview %></pre>
            </details>

            <form method="POST" action="/campaigns/<%= campaign.id %>/generate-image">
              <button type="submit" class="btn-primary full-width">Generar imagen ahora</button>
            </form>
          </div>
        <% } else { %>
          <p class="muted">Nuestro equipo está preparando y revisando el diseño. Te avisaremos cuando esté listo.</p>
        <% } %>

        <% if (campaign.ai_caption) { %>
          <h4>Copy propuesto</h4>
          <p><%= campaign.ai_caption %></p>
        <% } %>
        <% if (campaign.ai_hashtags) { %>
          <p class="hashtags"><%= campaign.ai_hashtags %></p>
        <% } %>

        <% if (campaign.status === 'publicado' && campaign.published_post_url) { %>
          <p><a href="<%= campaign.published_post_url %>" target="_blank" rel="noopener" class="btn-primary">Ver publicación en Facebook →</a></p>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>
