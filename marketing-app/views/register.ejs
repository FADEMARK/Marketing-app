<!DOCTYPE html>
<html lang="es">
<head>
  <title>Registrar mi negocio — MarketingHub</title>
  <%- include('partials/head') %>
</head>
<body>
  <%- include('partials/nav') %>

  <main class="form-page">
    <h1>Registra tu negocio</h1>
    <p class="subtitle">Con esto es suficiente para empezar a crear tus publicaciones.</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/register" enctype="multipart/form-data" class="card-form">
      <label>Nombre del negocio *
        <input type="text" name="name" required value="<%= form.name || '' %>" placeholder="Ej. Café Aurora" />
      </label>

      <label>Link de tu página de Facebook *
        <input type="url" name="fb_page_link" required value="<%= form.fb_page_link || '' %>" placeholder="https://facebook.com/tunegocio" />
      </label>

      <label>Giro del negocio *
        <input list="industries" type="text" name="industry" required value="<%= form.industry || '' %>" placeholder="Ej. Clínica dental, Restaurante, Gimnasio..." />
        <datalist id="industries">
          <option value="Clínica dental">
          <option value="Restaurante / Cafetería">
          <option value="Salón de belleza / Spa">
          <option value="Gimnasio / Fitness">
          <option value="Tienda de ropa / Boutique">
          <option value="Bienes raíces">
          <option value="Veterinaria">
          <option value="Consultorio médico">
          <option value="Ferretería">
          <option value="Escuela / Academia">
          <option value="Servicios profesionales (legal, contable, etc.)">
        </datalist>
      </label>

      <label>Teléfono / WhatsApp (opcional, se muestra en tus publicaciones)
        <input type="tel" name="phone" value="<%= form.phone || '' %>" placeholder="442 431 0914" />
      </label>

      <label>Dirección (opcional, se muestra en tus publicaciones)
        <input type="text" name="address" value="<%= form.address || '' %>" placeholder="Ej. Torre 1, piso 5, Centro Sur" />
      </label>

      <label>Nombre del doctor(a) o responsable (opcional — para consultorios médicos/dentales)
        <input type="text" name="doctor_name" value="<%= form.doctor_name || '' %>" placeholder="Ej. Dra. Ana López" />
      </label>

      <label>Correo electrónico *
        <input type="email" name="email" required value="<%= form.email || '' %>" />
      </label>

      <label>Contraseña *
        <input type="password" name="password" required minlength="6" />
      </label>

      <div class="two-col">
        <label>Color primario de marca
          <input type="color" name="brand_color_primary" value="<%= form.brand_color_primary || '#1877F2' %>" />
        </label>
        <label>Color secundario de marca
          <input type="color" name="brand_color_secondary" value="<%= form.brand_color_secondary || '#0B0B0B' %>" />
        </label>
      </div>

      <label>Logo (opcional)
        <input type="file" name="logo" accept="image/*" />
      </label>

      <button type="submit" class="btn-primary full-width">Crear cuenta</button>
    </form>

    <p class="switch-link">¿Ya tienes cuenta? <a href="/login">Inicia sesión</a></p>
  </main>
</body>
</html>
